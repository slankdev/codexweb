# Override which codex binary to spawn. Defaults to:
#   1. vendor/codex/codex-cli/bin/codex.js (if the submodule is set up & built)
#   2. `codex` on PATH
# CODEX_BIN=/usr/local/bin/codex

# Default working directory pre-filled in the "New task" dialog. Defaults to
# the process cwd of the Next.js server.
# CODEX_DEFAULT_CWD=/home/me/projects

# Forwarded to codex — typically required for it to call the upstream model.
# OPENAI_API_KEY=sk-...

# Extra arguments appended to every `codex exec` invocation. Use this to
# experiment with new codex flags without rebuilding the image. Honours
# single/double quotes for values that contain spaces.
# Examples:
#   CODEX_EXTRA_ARGS=-c responses.transport=http
#   CODEX_EXTRA_ARGS=--disable responses_websocket
# CODEX_EXTRA_ARGS=

# ----- Authentication (Google OAuth) -------------------------------------
# Required: secret used to HMAC-sign session cookies (>= 16 chars).
# Generate with: openssl rand -base64 32
# AUTH_SECRET=

# Google OAuth client credentials. Create an OAuth 2.0 Client ID in the
# Google Cloud Console (Application type: Web), and add the callback
# `https://<your-host>/api/auth/callback` (or http://localhost:3000/api/auth/callback)
# to "Authorized redirect URIs".
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: comma- or whitespace-separated allowlist of accounts that may
# sign in. Each entry is either a full email (alice@example.com) or a
# domain prefixed with `@` (e.g. `@example.com`). If unset, ANY verified
# Google account can sign in — DO NOT leave unset in production.
# ALLOWED_EMAILS=you@example.com,@your-company.com

# Optional: explicit base URL used to build the OAuth redirect URI. Auto-
# detected from request headers when unset. Set this if running behind a
# proxy that doesn't forward X-Forwarded-Proto/Host.
# AUTH_BASE_URL=https://codexweb.example.com
